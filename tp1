<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Bothayna Bessar – CV Portfolio</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    :root {
      --ink:     #1a1612;
      --stone:   #f7f5f2;
      --cream:   #fffef9;
      --rose:    #c9736a;
      --rose-lt: #f0e0de;
      --gold:    #b8924a;
      --muted:   #8a8075;
      --line:    #e8e2da;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--stone);
      color: var(--ink);
    }

    /* ─── SIDEBAR FIXE ─── */
    .sidebar {
      position: fixed;
      top: 0; left: 0;
      width: 300px;
      height: 100vh;
      background: var(--ink);
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 50px 30px 40px;
      z-index: 100;
      overflow-y: auto;
    }

    .sidebar-photo {
      width: 130px;
      height: 130px;
      border-radius: 50%;
      object-fit: cover;
      border: 3px solid var(--rose);
      box-shadow: 0 0 0 6px rgba(201,115,106,0.15);
      margin-bottom: 22px;
    }

    .sidebar-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.55rem;
      font-weight: 600;
      color: #fff;
      text-align: center;
      line-height: 1.25;
      margin-bottom: 6px;
    }

    .sidebar-title {
      font-size: 0.72rem;
      color: var(--rose);
      text-align: center;
      letter-spacing: 2px;
      text-transform: uppercase;
      margin-bottom: 30px;
      line-height: 1.5;
    }

    /* Nav sidebar */
    .sidebar-nav {
      width: 100%;
      margin-bottom: auto;
    }

    .sidebar-nav a {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 11px 16px;
      color: rgba(255,255,255,0.55);
      text-decoration: none;
      font-size: 0.82rem;
      font-weight: 500;
      letter-spacing: 0.5px;
      border-radius: 8px;
      transition: all 0.2s;
      margin-bottom: 2px;
    }

    .sidebar-nav a:hover {
      background: rgba(255,255,255,0.07);
      color: #fff;
      padding-left: 22px;
    }

    .sidebar-nav .nav-icon {
      font-size: 1rem;
      width: 20px;
      text-align: center;
    }

    /* Social dans sidebar */
    .sidebar-social {
      display: flex;
      flex-direction: column;
      gap: 10px;
      width: 100%;
      margin-top: 30px;
    }

    .sidebar-social a {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 14px;
      border-radius: 8px;
      text-decoration: none;
      font-size: 0.8rem;
      font-weight: 500;
      transition: transform 0.2s, opacity 0.2s;
      color: #fff;
    }

    .sidebar-social a:hover { transform: translateX(4px); opacity: 0.85; }

    .s-github   { background: #24292e; }
    .s-linkedin { background: #0077b5; }
    .s-email    { background: var(--rose); }

    .social-icon-img {
      width: 18px;
      height: 18px;
      flex-shrink: 0;
    }

    /* ─── CONTENU PRINCIPAL ─── */
    .main-content {
      margin-left: 300px;
      min-height: 100vh;
    }

    /* Page hero */
    .page-hero {
      background: var(--cream);
      padding: 60px 60px 50px;
      border-bottom: 1px solid var(--line);
      position: relative;
      overflow: hidden;
    }

    .page-hero::before {
      content: 'CYBER';
      position: absolute;
      right: -20px;
      bottom: -30px;
      font-family: 'Cormorant Garamond', serif;
      font-size: 9rem;
      font-weight: 700;
      color: rgba(201,115,106,0.05);
      letter-spacing: -4px;
      pointer-events: none;
      user-select: none;
    }

    .hero-label {
      font-size: 0.7rem;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: var(--rose);
      margin-bottom: 14px;
      font-weight: 500;
    }

    .hero-heading {
      font-family: 'Cormorant Garamond', serif;
      font-size: 3.6rem;
      font-weight: 300;
      line-height: 1.1;
      color: var(--ink);
      margin-bottom: 20px;
    }

    .hero-heading strong {
      font-weight: 700;
      color: var(--rose);
    }

    .hero-desc {
      max-width: 520px;
      font-size: 0.92rem;
      color: var(--muted);
      line-height: 1.8;
    }

    /* Sections */
    .section {
      padding: 50px 60px;
      border-bottom: 1px solid var(--line);
    }

    .section:last-child { border-bottom: none; }
    .section:nth-child(even) { background: var(--cream); }

    .section-header {
      display: flex;
      align-items: baseline;
      gap: 16px;
      margin-bottom: 35px;
    }

    .section-number {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1rem;
      color: var(--rose);
      font-weight: 400;
      letter-spacing: 1px;
    }

    .section-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.9rem;
      font-weight: 600;
      color: var(--ink);
    }

    .section-line {
      flex: 1;
      height: 1px;
      background: var(--line);
      margin-left: 8px;
    }

    /* ─── COMPÉTENCES ─── */
    .skills-cols {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }

    .skills-block h4 {
      font-size: 0.7rem;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 16px;
      font-weight: 500;
    }

    ul { list-style: none; padding: 0; }
    ol { padding-left: 18px; }

    ul li {
      padding: 8px 0;
      border-bottom: 1px solid var(--line);
      color: #444;
      font-size: 0.88rem;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    ul li::before {
      content: '';
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: var(--rose);
      flex-shrink: 0;
    }

    ol li {
      padding: 7px 0;
      color: #444;
      font-size: 0.88rem;
      border-bottom: 1px solid var(--line);
    }

    ol li::marker { color: var(--gold); font-weight: 600; }

    /* ─── TABLEAU ─── */
    .table-wrap { overflow-x: auto; }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.87rem;
    }

    thead tr {
      border-bottom: 2px solid var(--ink);
    }

    th {
      padding: 12px 16px 12px 0;
      text-align: left;
      font-size: 0.68rem;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--muted);
      font-weight: 500;
    }

    td {
      padding: 16px 16px 16px 0;
      border-bottom: 1px solid var(--line);
      color: #333;
      vertical-align: top;
    }

    td:first-child {
      font-size: 0.78rem;
      color: var(--muted);
      white-space: nowrap;
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.92rem;
    }

    td:nth-child(2) { font-weight: 500; color: var(--ink); }

    td:last-child {
      font-size: 0.72rem;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--rose);
      font-weight: 500;
    }

    tbody tr:hover td { background: rgba(201,115,106,0.03); }

    /* ─── CONTACT SECTION ─── */
    .contact-note {
      font-size: 0.92rem;
      color: var(--muted);
      line-height: 1.8;
      max-width: 480px;
      margin-bottom: 30px;
    }

    .contact-links {
      display: flex;
      flex-direction: column;
      gap: 14px;
      max-width: 420px;
    }

    .contact-link {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 16px 20px;
      border: 1px solid var(--line);
      border-radius: 4px;
      text-decoration: none;
      color: var(--ink);
      background: var(--cream);
      transition: all 0.2s;
    }

    .contact-link:hover {
      border-color: var(--rose);
      box-shadow: 4px 4px 0 var(--rose-lt);
      transform: translate(-2px, -2px);
    }

    .contact-link-icon {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1rem;
      flex-shrink: 0;
    }

    .ic-gh  { background: #f3f4f6; }
    .ic-li  { background: #dbeafe; }
    .ic-em  { background: var(--rose-lt); }

    .contact-link-text strong {
      display: block;
      font-size: 0.85rem;
      font-weight: 600;
      margin-bottom: 1px;
    }

    .contact-link-text small {
      font-size: 0.75rem;
      color: var(--muted);
    }

    /* ─── FOOTER ─── */
    footer {
      background: var(--ink);
      color: rgba(255,255,255,0.4);
      text-align: center;
      padding: 22px;
      font-size: 0.78rem;
      margin-left: 300px;
    }

    footer a { color: var(--rose); text-decoration: none; }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 768px) {
      .sidebar {
        position: relative;
        width: 100%;
        height: auto;
        flex-direction: column;
        padding: 40px 20px 30px;
      }
      .sidebar-social { flex-direction: row; flex-wrap: wrap; justify-content: center; }
      .sidebar-social a { flex: 1; min-width: 120px; justify-content: center; }
      .main-content { margin-left: 0; }
      footer { margin-left: 0; }
      .page-hero, .section { padding: 40px 24px; }
      .hero-heading { font-size: 2.5rem; }
      .skills-cols { grid-template-columns: 1fr; gap: 25px; }
    }
  </style>
</head>
