<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TP2 – Formulaire d'inscription | Bothayna Bessar</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    :root {
      --ink:     #14110e;
      --stone:   #f6f4f1;
      --cream:   #fffef9;
      --rose:    #c9736a;
      --rose-lt: #f0e0de;
      --rose-dk: #a85a52;
      --muted:   #8a8075;
      --line:    #e8e2da;
      --green:   #3d7a56;
      --red:     #b94a4a;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--stone);
      color: var(--ink);
      min-height: 100vh;
    }

    /* ── HEADER ── */
    header {
      background: var(--ink);
      padding: 22px 40px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.4rem;
      font-weight: 700;
      color: white;
    }

    .logo span { color: var(--rose); }

    .tp-badge {
      background: var(--rose);
      color: white;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 2px;
      text-transform: uppercase;
      padding: 6px 16px;
      border-radius: 2px;
    }

    /* ── NAV ── */
    nav {
      background: #1e1a16;
      padding: 0 40px;
      display: flex;
    }

    nav a {
      color: rgba(255,255,255,0.45);
      text-decoration: none;
      padding: 12px 16px;
      font-size: 0.82rem;
      border-bottom: 2px solid transparent;
      transition: all 0.2s;
    }

    nav a:hover { color: white; border-bottom-color: var(--rose); }
    nav a.active { color: var(--rose); border-bottom-color: var(--rose); }

    /* ── WRAPPER ── */
    .wrapper {
      max-width: 780px;
      margin: 40px auto;
      padding: 0 20px 60px;
    }

    /* ── INTRO ── */
    .intro {
      background: var(--cream);
      border-left: 4px solid var(--rose);
      border-radius: 0 8px 8px 0;
      padding: 20px 24px;
      margin-bottom: 28px;
    }

    .intro h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.7rem;
      font-weight: 600;
      margin-bottom: 6px;
    }

    .intro p { font-size: 0.85rem; color: var(--muted); line-height: 1.7; }
    .intro p .req { color: var(--rose); font-weight: 600; }

    /* ── FIELDSET ── */
    fieldset {
      background: var(--cream);
      border: 1px solid var(--line);
      border-radius: 10px;
      padding: 28px 28px 20px;
      margin-bottom: 20px;
    }

    legend {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--ink);
      padding: 0 10px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    legend::before {
      content: '';
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--rose);
      display: inline-block;
    }

    /* ── GRILLE 2 COL ── */
    .row-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }

    /* ── FORM GROUP ── */
    .form-group { margin-bottom: 16px; }
    .form-group:last-child { margin-bottom: 0; }

    label {
      display: block;
      font-size: 0.8rem;
      font-weight: 500;
      margin-bottom: 6px;
    }

    .req { color: var(--rose); margin-left: 2px; }

    /* ── INPUTS ── */
    input[type="text"],
    input[type="email"],
    input[type="tel"],
    input[type="password"],
    input[type="date"],
    input[type="file"],
    select,
    textarea {
      width: 100%;
      background: white;
      border: 1.5px solid var(--line);
      border-radius: 6px;
      padding: 10px 14px;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.88rem;
      color: var(--ink);
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    input:focus, select:focus, textarea:focus {
      border-color: var(--rose);
      box-shadow: 0 0 0 3px rgba(201,115,106,0.12);
    }

    input:valid:not(:placeholder-shown):not([type="file"]):not([type="date"]) {
      border-color: var(--green);
    }

    input:invalid:not(:placeholder-shown) { border-color: var(--red); }
    input::placeholder, textarea::placeholder { color: #c5bfb8; font-size: 0.85rem; }
    textarea { resize: vertical; min-height: 100px; }
    input[type="file"] { padding: 8px 12px; cursor: pointer; color: var(--muted); }

    .hint { font-size: 0.73rem; color: var(--muted); margin-top: 5px; line-height: 1.5; }

    /* Messages d'erreur personnalisés */
    .error-msg {
      font-size: 0.73rem;
      color: var(--red);
      margin-top: 4px;
      display: none;
    }

    input:invalid:not(:placeholder-shown) ~ .error-msg { display: block; }

    /* ── RADIO / CHECKBOX ── */
    .options-group { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 6px; }

    .opt { display: flex; align-items: center; gap: 7px; cursor: pointer; }

    .opt input[type="radio"],
    .opt input[type="checkbox"] {
      width: 16px;
      height: 16px;
      accent-color: var(--rose);
      cursor: pointer;
      flex-shrink: 0;
    }

    .opt label {
      margin-bottom: 0;
      font-size: 0.85rem;
      color: #444;
      font-weight: 400;
      cursor: pointer;
    }

    /* ── TEXTAREA COMPTEUR ── */
    .textarea-wrap { position: relative; }

    .char-count {
      position: absolute;
      bottom: 8px;
      right: 10px;
      font-size: 0.7rem;
      color: var(--muted);
      background: white;
      padding: 0 4px;
      pointer-events: none;
    }

    /* ── CGU ── */
    .cgu-box {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      background: rgba(201,115,106,0.06);
      border: 1px solid var(--rose-lt);
      border-radius: 8px;
      padding: 16px;
      margin-top: 18px;
    }

    .cgu-box input[type="checkbox"] {
      width: 17px;
      height: 17px;
      accent-color: var(--rose);
      margin-top: 2px;
      flex-shrink: 0;
    }

    .cgu-box label {
      margin-bottom: 0;
      font-size: 0.83rem;
      color: #444;
      line-height: 1.65;
      font-weight: 400;
    }

    .cgu-box a { color: var(--rose); text-decoration: none; }
    .cgu-box a:hover { text-decoration: underline; }

    /* ── BOUTONS ── */
    .form-actions {
      display: flex;
      gap: 14px;
      margin-top: 26px;
    }

    .btn-submit {
      flex: 1;
      padding: 13px;
      background: var(--ink);
      color: white;
      border: none;
      border-radius: 6px;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.92rem;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.2s, transform 0.1s;
    }

    .btn-submit:hover { background: var(--rose); transform: translateY(-1px); }
    .btn-submit:active { transform: translateY(0); }

    .btn-reset {
      padding: 13px 26px;
      background: transparent;
      color: var(--muted);
      border: 1.5px solid var(--line);
      border-radius: 6px;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.88rem;
      cursor: pointer;
      transition: all 0.2s;
    }

    .btn-reset:hover { border-color: var(--rose); color: var(--rose); }

    /* ── FOOTER ── */
    footer {
      background: var(--ink);
      color: rgba(255,255,255,0.4);
      text-align: center;
      padding: 18px;
      font-size: 0.78rem;
    }

    footer a { color: var(--rose); text-decoration: none; }
    footer a:hover { text-decoration: underline; }

    /* ── RESPONSIVE ── */
    @media (max-width: 600px) {
      header { padding: 16px 20px; }
      nav { padding: 0 16px; }
      .wrapper { padding: 0 14px 40px; }
      fieldset { padding: 20px 16px 16px; }
      .row-2 { grid-template-columns: 1fr; }
      .form-actions { flex-direction: column; }
    }
  </style>
</head>
<body>

<!-- ══ HEADER ══ -->
<header>
  <div class="logo">Bothayna <span>Bessar</span></div>
  <span class="tp-badge">TP 02</span>
</header>

<!-- ══ NAV ══ -->
<nav aria-label="Navigation principale">
  <a href="../tp1/index.html">TP1 – CV</a>
  <a href="index.html" class="active">TP2 – Formulaire</a>
  <a href="../tp3/index.html">TP3 – Site vitrine</a>
</nav>

<!-- ══ CONTENU ══ -->
<div class="wrapper">

  <div class="intro">
    <h1>Formulaire d'inscription</h1>
    <p>Remplissez tous les champs marqués <span class="req">*</span> pour créer votre compte. Vos données sont traitées de manière sécurisée.</p>
  </div>

  <form action="#" method="post" novalidate>

    <!-- ══ 1. INFORMATIONS PERSONNELLES ══ -->
    <fieldset>
      <legend>Informations personnelles</legend>

      <div class="row-2" style="margin-top:18px;">

        <div class="form-group">
          <label for="prenom">Prénom <span class="req">*</span></label>
          <input
            type="text"
            id="prenom"
            name="prenom"
            placeholder="Votre prénom"
            required
            minlength="2"
            autocomplete="given-name"
            title="Minimum 2 caractères"
          />
          <span class="error-msg">⚠ Prénom invalide (min. 2 caractères)</span>
        </div>

        <div class="form-group">
          <label for="nom">Nom <span class="req">*</span></label>
          <input
            type="text"
            id="nom"
            name="nom"
            placeholder="Votre nom de famille"
            required
            minlength="2"
            autocomplete="family-name"
            title="Minimum 2 caractères"
          />
          <span class="error-msg">⚠ Nom invalide (min. 2 caractères)</span>
        </div>

      </div>

      <div class="row-2">

        <div class="form-group">
          <label for="email">Email <span class="req">*</span></label>
          <input
            type="email"
            id="email"
            name="email"
            placeholder="exemple@domaine.com"
            required
            autocomplete="email"
            title="Entrez une adresse email valide"
          />
          <span class="error-msg">⚠ Adresse email invalide</span>
          <p class="hint">Format attendu : adresse@domaine.com</p>
        </div>

        <div class="form-group">
          <label for="tel">Téléphone <span class="req">*</span></label>
          <input
            type="tel"
            id="tel"
            name="tel"
            placeholder="0600000000"
            required
            pattern="0[67]\d{8}"
            autocomplete="tel"
            title="Format marocain : 06 ou 07 suivi de 8 chiffres"
          />
          <span class="error-msg">⚠ Format invalide — exemple : 0612345678</span>
          <p class="hint">Format : 06XXXXXXXX ou 07XXXXXXXX</p>
        </div>

      </div>

      <div class="row-2">

        <div class="form-group">
          <label for="ddn">Date de naissance <span class="req">*</span></label>
          <input
            type="date"
            id="ddn"
            name="date_naissance"
            required
            max="2007-03-18"
            autocomplete="bday"
            title="Vous devez avoir au moins 18 ans"
          />
          <p class="hint">Âge minimum requis : 18 ans</p>
        </div>

        <div class="form-group">
          <label for="pays">Pays <span class="req">*</span></label>
          <input
            type="text"
            id="pays"
            name="pays"
            placeholder="Tapez votre pays..."
            required
            list="pays-list"
            autocomplete="country-name"
            title="Sélectionnez ou tapez votre pays"
          />
          <datalist id="pays-list">
            <option value="Maroc" />
            <option value="France" />
            <option value="Algérie" />
            <option value="Tunisie" />
            <option value="Sénégal" />
            <option value="Côte d'Ivoire" />
            <option value="Canada" />
            <option value="Belgique" />
            <option value="Suisse" />
            <option value="Espagne" />
            <option value="Allemagne" />
          </datalist>
          <p class="hint">Tapez pour voir les suggestions</p>
        </div>

      </div>

      <div class="form-group">
        <label>Genre <span class="req">*</span></label>
        <div class="options-group">
          <div class="opt">
            <input type="radio" id="femme" name="genre" value="F" required />
            <label for="femme">Femme</label>
          </div>
          <div class="opt">
            <input type="radio" id="homme" name="genre" value="M" />
            <label for="homme">Homme</label>
          </div>
          <div class="opt">
            <input type="radio" id="autre-g" name="genre" value="A" />
            <label for="autre-g">Autre</label>
          </div>
          <div class="opt">
            <input type="radio" id="nr-g" name="genre" value="NR" />
            <label for="nr-g">Préfère ne pas préciser</label>
          </div>
        </div>
      </div>

    </fieldset>

    <!-- ══ 2. SÉCURITÉ ══ -->
    <fieldset>
      <legend>Sécurité du compte</legend>

      <div class="row-2" style="margin-top:18px;">

        <div class="form-group">
          <label for="mdp">Mot de passe <span class="req">*</span></label>
          <input
            type="password"
            id="mdp"
            name="password"
            placeholder="Votre mot de passe"
            required
            minlength="8"
            pattern="(?=.*[A-Z])(?=.*\d).{8,}"
            autocomplete="new-password"
            title="Min. 8 caractères, 1 majuscule et 1 chiffre"
          />
          <span class="error-msg">⚠ Min. 8 caractères, 1 majuscule, 1 chiffre</span>
          <p class="hint">Min. 8 caractères · 1 majuscule · 1 chiffre</p>
        </div>

        <div class="form-group">
          <label for="mdp2">Confirmer le mot de passe <span class="req">*</span></label>
          <input
            type="password"
            id="mdp2"
            name="password_confirm"
            placeholder="Répétez le mot de passe"
            required
            minlength="8"
            pattern="(?=.*[A-Z])(?=.*\d).{8,}"
            autocomplete="new-password"
            title="Doit correspondre au mot de passe saisi"
          />
          <span class="error-msg">⚠ Les mots de passe ne correspondent pas</span>
        </div>

      </div>
    </fieldset>

    <!-- ══ 3. PROFIL ══ -->
    <fieldset>
      <legend>Profil &amp; Centres d'intérêt</legend>

      <div class="form-group" style="margin-top:18px;">
        <label>Centres d'intérêt</label>
        <div class="options-group">
          <div class="opt">
            <input type="checkbox" id="ci-cyber" name="interets" value="cybersecurite" />
            <label for="ci-cyber">Cybersécurité</label>
          </div>
          <div class="opt">
            <input type="checkbox" id="ci-dev" name="interets" value="developpement" />
            <label for="ci-dev">Développement web</label>
          </div>
          <div class="opt">
            <input type="checkbox" id="ci-ia" name="interets" value="ia" />
            <label for="ci-ia">Intelligence artificielle</label>
          </div>
          <div class="opt">
            <input type="checkbox" id="ci-reseau" name="interets" value="reseaux" />
            <label for="ci-reseau">Réseaux</label>
          </div>
          <div class="opt">
            <input type="checkbox" id="ci-cloud" name="interets" value="cloud" />
            <label for="ci-cloud">Cloud computing</label>
          </div>
          <div class="opt">
            <input type="checkbox" id="ci-ctf" name="interets" value="ctf" />
            <label for="ci-ctf">CTF &amp; Hacking éthique</label>
          </div>
        </div>
      </div>

      <div class="form-group">
        <label for="photo">Photo de profil</label>
        <input
          type="file"
          id="photo"
          name="photo"
          accept="image/jpeg,image/png,image/webp"
        />
        <p class="hint">Formats : JPG, PNG, WEBP · Max 2 Mo</p>
      </div>

      <div class="form-group">
        <label for="bio">Biographie</label>
        <div class="textarea-wrap">
          <textarea
            id="bio"
            name="bio"
            placeholder="Présentez-vous en quelques mots..."
            maxlength="300"
            oninput="document.getElementById('count').textContent = this.value.length"
          ></textarea>
          <span class="char-count"><span id="count">0</span>/300</span>
        </div>
        <p class="hint">Maximum 300 caractères</p>
      </div>

    </fieldset>

    <!-- ══ 4. CGU ══ -->
    <fieldset>
      <legend>Conditions d'utilisation</legend>
      <div class="cgu-box">
        <input type="checkbox" id="cgu" name="cgu" required />
        <label for="cgu">
          J'ai lu et j'accepte les
          <a href="#" target="_blank" rel="noopener noreferrer">Conditions Générales d'Utilisation</a>
          et la
          <a href="#" target="_blank" rel="noopener noreferrer">Politique de confidentialité</a>.
          <span class="req">*</span>
        </label>
      </div>
    </fieldset>

    <!-- ══ BOUTONS ══ -->
    <div class="form-actions">
      <button type="submit" class="btn-submit">Créer mon compte →</button>
      <button type="reset" class="btn-reset">Réinitialiser</button>
    </div>

  </form>
</div>

